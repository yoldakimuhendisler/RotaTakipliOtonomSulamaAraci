# Monorepo Development Environment Variables

# Network & AI Server
AI_SERVER_HOST=192.168.50.2
AI_SERVER_PORT=9937
AI_ENDPOINT=http://${AI_SERVER_HOST}:${AI_SERVER_PORT}/infer

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./plant_robot.db

# ROS 2 Parameters
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
MIN_MOISTURE_THRESHOLD=40.0 # Yüzde [%]

# Tank Capacity
TANK_CAPACITY_LITERS=5.0
WATER_CONSUMPTION_PER_PLANT=0.2 # Ortalama L
